// ─────────────────────────────────────────────
//  CONSTANT - max number of feedback allowed
// ─────────────────────────────────────────────

const int MAX = 100;

// ─────────────────────────────────────────────
//  STRUCT - holds one feedback record
// ─────────────────────────────────────────────

struct Feedback {
    int    id;
    string name;
    string rollNo;
    string category;
    string text;
    string sentiment;
    string suggestion;
};

// ─────────────────────────────────────────────
//  GLOBAL VARIABLES
// ─────────────────────────────────────────────

Feedback db[MAX];      // array to store all feedback
int total  = 0;        // count of feedbacks stored
int nextId = 1;        // ID counter

// ─────────────────────────────────────────────
//  FUNCTION: convert string to lowercase
//  (so keyword search is case-insensitive)
// ─────────────────────────────────────────────

string toLower(string s) {
    for (int i = 0; i < s.length(); i++) {
        if (s[i] >= 'A' && s[i] <= 'Z') {
            s[i] = s[i] + 32;
        }
    }
    return s;
}

// ─────────────────────────────────────────────
//  FUNCTION: check if a keyword is in text
// ─────────────────────────────────────────────

bool hasWord(string text, string word) {
    text = toLower(text);
    word = toLower(word);
    int tLen = text.length();
    int wLen = word.length();
    for (int i = 0; i <= tLen - wLen; i++) {
        if (text.substr(i, wLen) == word) {
            return true;
        }
    }
    return false;
}

// ─────────────────────────────────────────────
//  FUNCTION: AI Sentiment Analysis
//  Rule-based: counts positive vs negative words
// ─────────────────────────────────────────────

string analyzeSentiment(string text) {
    string pos[20] = {
        "good","great","excellent","amazing","helpful",
        "clear","best","love","enjoy","wonderful",
        "fantastic","nice","happy","clean","comfortable",
        "outstanding","effective","brilliant","superb","satisfied"
    };

    string neg[20] = {
        "bad","poor","boring","terrible","awful",
        "slow","dirty","broken","useless","rude",
        "unfair","worst","hate","noisy","confusing",
        "late","absent","dull","old","disappointing"
    };

    int posScore = 0;
    int negScore = 0;

    for (int i = 0; i < 20; i++) {
        if (hasWord(text, pos[i])) posScore++;
    }

    for (int i = 0; i < 20; i++) {
        if (hasWord(text, neg[i])) negScore++;
    }

    if (posScore > negScore)  return "Positive";
    if (negScore > posScore)  return "Negative";
    return "Neutral";
}

// ─────────────────────────────────────────────
//  FUNCTION: return suggestion based on
//  category and sentiment
// ─────────────────────────────────────────────

string getSuggestion(string cat, string sent) {

    if (cat == "Teaching") {
        if (sent == "Positive") return "Great! Faculty should keep using this teaching style.";
        if (sent == "Negative") return "Faculty should use visual aids and hold extra doubt sessions.";
        return "Faculty can add more real-world examples to improve lectures.";
    }

    if (cat == "Faculty") {
        if (sent == "Positive") return "Faculty behaviour is appreciated. Keep it up!";
        if (sent == "Negative") return "Administration should review faculty conduct and provide training.";
        return "Faculty should be more approachable and interactive with students.";
    }

    if (cat == "Facilities") {
        if (sent == "Positive") return "Facilities are good. Continue regular maintenance.";
        if (sent == "Negative") return "Immediate action needed: fix equipment and improve cleanliness.";
        return "Upgrade aging equipment and improve WiFi coverage.";
    }

    // Overall (default)
    if (sent == "Positive") return "Overall experience is positive. Maintain current standards.";
    if (sent == "Negative") return "Management must address all student issues urgently.";
    return "Conduct a student survey to find specific areas to improve.";
}

// ─────────────────────────────────────────────
