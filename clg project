void line() {
    cout << "--------------------------------------------" << endl;
}

// ─────────────────────────────────────────────
//  FEATURE 1: Submit Feedback
// ─────────────────────────────────────────────

void submitFeedback() {
    if (total >= MAX) {
        cout << "Storage full!" << endl;
        return;
    }

    cout << endl;
    cout << "======= SUBMIT FEEDBACK =======" << endl;

    Feedback fb;
    fb.id = nextId;
    nextId++;

    cout << "Your name      : ";
    getline(cin, fb.name);

    cout << "Roll number    : ";
    getline(cin, fb.rollNo);

    cout << endl;
    cout << "Select category:" << endl;
    cout << "  1. Teaching Method" << endl;
    cout << "  2. Faculty Behaviour" << endl;
    cout << "  3. Campus Facilities" << endl;
    cout << "  4. Overall Experience" << endl;
    cout << "Choice (1-4)   : ";

    int ch;
    cin >> ch;
    cin.ignore();

    if      (ch == 1) fb.category = "Teaching";
    else if (ch == 2) fb.category = "Faculty";
    else if (ch == 3) fb.category = "Facilities";
    else              fb.category = "Overall";

    cout << "Your feedback  : ";
    getline(cin, fb.text);

    if (fb.text == "") {
        cout << "Feedback cannot be empty!" << endl;
        return;
    }

    // Run AI analysis
    fb.sentiment  = analyzeSentiment(fb.text);
    fb.suggestion = getSuggestion(fb.category, fb.sentiment);

    // Save in array
    db[total] = fb;
    total++;

    cout << endl;
    line();
    cout << "Feedback submitted! ID: #" << fb.id << endl;
    cout << "Sentiment  : " << fb.sentiment << endl;
    cout << "Suggestion : " << fb.suggestion << endl;
    line();
}

// ─────────────────────────────────────────────
//  FEATURE 2: View All Feedback
// ─────────────────────────────────────────────

void viewAll() {
    cout << endl;
    cout << "======= ALL FEEDBACK =======" << endl;

    if (total == 0) {
        cout << "No records found." << endl;
        return;
    }

    for (int i = 0; i < total; i++) {
        cout << endl;
        cout << "ID         : #" << db[i].id << endl;
        cout << "Name       : " << db[i].name << endl;
        cout << "Roll No    : " << db[i].rollNo << endl;
        cout << "Category   : " << db[i].category << endl;
        cout << "Feedback   : " << db[i].text << endl;
        cout << "Sentiment  : " << db[i].sentiment << endl;
        cout << "Suggestion : " << db[i].suggestion << endl;
        line();
    }
}

// ─────────────────────────────────────────────
//  FEATURE 3: Sentiment Report
// ─────────────────────────────────────────────

void showReport() {
    cout << endl;
    cout << "======= SENTIMENT REPORT =======" << endl;

    if (total == 0) {
        cout << "No data available." << endl;
        return;
    }

    int pos = 0, neu = 0, neg = 0;

    for (int i = 0; i < total; i++) {
        if      (db[i].sentiment == "Positive") pos++;
        else if (db[i].sentiment == "Negative") neg++;
        else                                    neu++;
    }

    cout << "Total    : " << total << " feedback(s)" << endl;
    line();
    cout << "Positive : " << pos << endl;
    cout << "Neutral  : " << neu << endl;
    cout << "Negative : " << neg << endl;
    line();

    if (pos >= neg && pos >= neu)
        cout << "Result: GOOD - Students are mostly satisfied." << endl;
    else if (neg > pos)
        cout << "Result: POOR - Action needed! Many students are unhappy." << endl;
    else
        cout << "Result: AVERAGE - Some improvements are needed." << endl;

    line();
}

// ─────────────────────────────────────────────
//  FEATURE 4: Search by Roll Number
// ─────────────────────────────────────────────

void searchByRoll() {
    cout << endl;
    cout << "======= SEARCH FEEDBACK =======" << endl;
    cout << "Enter roll number: ";

    string roll;
    getline(cin, roll);

    bool found = false;

    for (int i = 0; i < total; i++) {
        if (toLower(db[i].rollNo) == toLower(roll)) {
            found = true;
            cout << endl;
            cout << "ID         : #" << db[i].id << endl;
            cout << "Name       : " << db[i].name << endl;
            cout << "Category   : " << db[i].category << endl;
            cout << "Feedback   : " << db[i].text << endl;
            cout << "Sentiment  : " << db[i].sentiment << endl;
            cout << "Suggestion : " << db[i].suggestion << endl;
            line();
        }
    }

    if (!found) {
        cout << "No record found for: " << roll << endl;
    }
}

// ─────────────────────────────────────────────
