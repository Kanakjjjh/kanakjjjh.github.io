        cout << "No data to save." << endl;
        return;
    }

    ofstream file("report.txt");

    if (!file) {
        cout << "Error: Cannot create file." << endl;
        return;
    }

    int pos = 0, neu = 0, neg = 0;

    file << "AI-Assisted Student Feedback Report" << endl;
    file << "====================================" << endl;
    file << "Total Feedback: " << total << endl << endl;

    for (int i = 0; i < total; i++) {
        file << "ID         : #" << db[i].id << endl;
        file << "Name       : " << db[i].name << endl;
        file << "Roll No    : " << db[i].rollNo << endl;
        file << "Category   : " << db[i].category << endl;
        file << "Feedback   : " << db[i].text << endl;
        file << "Sentiment  : " << db[i].sentiment << endl;
        file << "Suggestion : " << db[i].suggestion << endl;
        file << "--------------------------------------------" << endl;

        if      (db[i].sentiment == "Positive") pos++;
        else if (db[i].sentiment == "Negative") neg++;
        else                                    neu++;
    }

    file << endl << "SUMMARY" << endl;
    file << "Positive : " << pos << endl;
    file << "Neutral  : " << neu << endl;
    file << "Negative : " << neg << endl;
    file.close();

    cout << "Report saved to report.txt!" << endl;
}

